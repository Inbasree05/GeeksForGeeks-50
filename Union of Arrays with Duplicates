class Solution {
    public static ArrayList<Integer> findUnion(int[] a, int[] b) {
        // code here
        Set<Integer>s=new Set<>();
        for(int i=0;i<a.length;i++){
            s.add(a[i]);
        }
        for(int i=0;i<b.length;i++){
            s.add(b[i]);
        }
        ArrayList<Integer>ans=new ArrayList<>();
        for(int c:s.size()){
            ans.add(c);
        }
        return ans;
    }
}
