class Solution {
    public List<Integer> frequencyCount(int[] arr) {
        // code here
        Map<Integer,Integer>s=new HashMap<>();
        List<Integer>ans=new ArrayList<>();
        int n=arr.length;
        for(int i=1;i<=n;i++){
            s.put(i,0);
        }
        for(int i=0;i<n;i++){
            s.put(arr[i],s.getOrDefault(arr[i],0)+1);
        }
        for(int i=1;i<=s.size();i++){
            ans.add(s.get(i));
        }
        return ans;
    }
}
