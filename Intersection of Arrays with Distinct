class Solution {
    public static int intersectSize(int a[], int b[]) {
        // Your code here
        Set<Integer>s=new HashSet<>();
        Set<Integer>result=new HashSet<>();
        for(int i=0;i<a.length;i++){
            s.add(a[i]);
        }
        for(int i=0;i<b.length;i++){
            if(s.contains(b[i])){
                result.add(b[i]);
            }
        }
        return result.size();
    }
}
